# Solara Optima Platform Configuration

# Application
APP_NAME="Solara Optima Platform"
# Set DEBUG=true ONLY for local development. NEVER enable in production —
# leaks stack traces and exposes /docs.
DEBUG=false
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated). For production set to your frontend domain(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Location (Bandung, Indonesia)
LATITUDE=-6.9147
LONGITUDE=107.6098
ALTITUDE=768
TIMEZONE=Asia/Jakarta

# Market
CURRENCY=IDR
USD_IDR_RATE=15500
CARBON_PRICE=50000

# Database — REPLACE password before deploying. Use a strong random value.
DATABASE_URL=postgresql://user:CHANGE_ME@localhost:5432/solara_optima
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=solara_optima

# Redis
REDIS_URL=redis://localhost:6379/0

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5

# Optimization
SOLVER_NAME=cbc
SOLVER_TIME_LIMIT=300

# Logging
LOG_LEVEL=INFO
